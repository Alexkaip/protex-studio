{% comment %}
  Protex Studio Shopify Section
  Diese Section bettet den Protex-Konfigurator von Vercel in Shopify ein.
{% endcomment %}

<section class="protex-configurator-section">
  <iframe
    id="protex-configurator-frame"
    class="protex-configurator-frame"
    src="{{ section.settings.configurator_url }}"
    title="Protex Produkt-Konfigurator"
    loading="lazy"
  ></iframe>
</section>

{{ 'protex-shopify-cart-bridge.js' | asset_url | script_tag }}

<style>
  .protex-configurator-section {
    width: 100%;
    min-height: 900px;
  }

  .protex-configurator-frame {
    width: 100%;
    min-height: 900px;
    border: 0;
    display: block;
  }
</style>

{% schema %}
{
  "name": "Protex Konfigurator",
  "settings": [
    {
      "type": "text",
      "id": "configurator_url",
      "label": "Konfigurator URL",
      "default": "https://protex-studio.vercel.app/"
    }
  ],
  "presets": [
    {
      "name": "Protex Konfigurator"
    }
  ]
}
{% endschema %}
