{% comment %}
  Protex Studio Shopify Section
  Diese Section bettet den Protex-Konfigurator von Vercel in Shopify ein.
{% endcomment %}

<section class="protex-configurator-section">
  <iframe
    id="protex-configurator-frame"
    class="protex-configurator-frame"
    src="{{ section.settings.configurator_url }}"
    title="Protex Produkt-Konfigurator"
    loading="lazy"
  ></iframe>
</section>

<script>
  window.PROTEX_PRINT_FEE_VARIANT_ID = {{ section.settings.print_fee_variant_id | json }};
  window.PROTEX_PRINT_FEE_HANDLE = {{ section.settings.print_fee_handle | json }};
  window.PROTEX_PRODUCT_MAP = [
    {% assign protex_product_source = section.settings.product_source_collection %}
    {% if protex_product_source == blank %}
      {% assign protex_product_source = collections.all %}
    {% endif %}
    {% for product in protex_product_source.products limit: 250 %}
      {
        title: {{ product.title | json }},
        handle: {{ product.handle | json }},
        firstVariantId: {{ product.selected_or_first_available_variant.id | default: product.variants.first.id | json }},
        variants: [
          {% for variant in product.variants %}
            {
              id: {{ variant.id | json }},
              title: {{ variant.title | json }},
              option1: {{ variant.option1 | json }},
              option2: {{ variant.option2 | json }},
              option3: {{ variant.option3 | json }},
              sku: {{ variant.sku | json }},
              available: {{ variant.available | json }},
              price: {{ variant.price | divided_by: 100.0 | json }}
            }{% unless forloop.last %},{% endunless %}
          {% endfor %}
        ]
      }{% unless forloop.last %},{% endunless %}
    {% endfor %}
  ];
</script>
{{ 'protex-shopify-cart-bridge.js' | asset_url | script_tag }}

<style>
  .protex-configurator-section {
    width: 100%;
    min-height: 900px;
  }

  .protex-configurator-frame {
    width: 100%;
    min-height: 900px;
    border: 0;
    display: block;
  }
</style>

{% schema %}
{
  "name": "Protex Konfigurator",
  "settings": [
    {
      "type": "text",
      "id": "configurator_url",
      "label": "Konfigurator URL",
      "default": "https://protex-studio.vercel.app/"
    },
    {
      "type": "text",
      "id": "print_fee_variant_id",
      "label": "Shopify Variant ID fuer Druckkosten",
      "default": "0"
    },
    {
      "type": "text",
      "id": "print_fee_handle",
      "label": "Shopify Produkt-Handle fuer Druckkosten",
      "default": "dtf-druck"
    },
    {
      "type": "collection",
      "id": "product_source_collection",
      "label": "Produkt-Kollektion fuer Warenkorb-Suche"
    }
  ],
  "presets": [
    {
      "name": "Protex Konfigurator"
    }
  ]
}
{% endschema %}

